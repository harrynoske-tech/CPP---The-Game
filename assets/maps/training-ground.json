class TrainingGround {

    constructor(scene) {
        this.scene = scene;
    }

    build() {

        const width = this.scene.scale.width;
        const height = this.scene.scale.height;

        // Grass
        this.scene.add.rectangle(
            width / 2,
            height / 2,
            width,
            height,
            0x4f7d4a
        );

        // Road
        this.scene.add.rectangle(
            width / 2,
            height / 2,
            width,
            180,
            0x3d3d3d
        );

        // Centre line
        for (let x = 0; x < width; x += 80) {

            this.scene.add.rectangle(
                x + 20,
                height / 2,
                40,
                6,
                0xffffff
            );

        }

        // Footpaths
        this.scene.add.rectangle(
            width / 2,
            height / 2 - 105,
            width,
            30,
            0xbdbdbd
        );

        this.scene.add.rectangle(
            width / 2,
            height / 2 + 105,
            width,
            30,
            0xbdbdbd
        );

    }

}
